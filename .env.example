# Server Configuration
PORT=5000

# Database Configuration
MONGO_URI=mongodb://username:password@host:port/database

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here

# Email Configuration (Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Application URL
BASE_URL=http://localhost:5000

# Notes:
# - Generate a strong JWT_SECRET using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# - For Gmail, use App Password (not your regular password): https://myaccount.google.com/apppasswords
# - Update BASE_URL to your production URL when deploying
